# Flask Config
SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=development
FLASK_DEBUG=True

# Database
DATABASE_URL=sqlite:///doctor_booking.db
# For MySQL use: mysql+pymysql://user:password@localhost/doctor_booking

# Stripe Payment (get keys from https://stripe.com)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Mail (optional - for booking confirmations)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# App URL
BASE_URL=http://localhost:5000

# Consultation fee in cents (e.g., 5000 = $50.00)
DEFAULT_CONSULTATION_FEE=5000